{
  "name": "meridian",
  "version": "0.1.0",
  "private": true,
  "description": "Context-aware incident intelligence on Splunk + MongoDB + Gemini, built on MetisOS protocols (ContextSync + USC)",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "meridian": "pnpm --filter @meridian/cli dev --"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "protobufjs",
      "@google/genai",
      "@modelcontextprotocol/ext-apps",
      "cpu-features",
      "kerberos",
      "mongodb-client-encryption",
      "os-dns-native",
      "ssh2"
    ]
  }
}
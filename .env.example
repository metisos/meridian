# ─── MongoDB Atlas ──────────────────────────────────────────────────────────
# Cluster credentials. Password gets URL-encoded at runtime; you may include
# special chars like `@`, `!`, `#` etc. without escaping here.
MONGODB_USER=your-atlas-user
MONGODB_PASSWORD=replace-me
MONGODB_HOST=cluster0.xxxxxx.mongodb.net
MONGODB_APP_NAME=Cluster0
MONGODB_DB=meridian_db

# ─── Gemini / Vertex AI ─────────────────────────────────────────────────────
# Choose ONE backend. Vertex is preferred for production (ADC, no API key).
GEMINI_BACKEND=vertex          # "vertex" | "apikey"
GEMINI_MODEL=gemini-3.1-pro-preview
GCP_PROJECT=your-gcp-project
VERTEX_LOCATION=global          # Gemini 3.1 Pro requires "global"
# GEMINI_API_KEY=                # Only set when GEMINI_BACKEND=apikey

# ─── Splunk Enterprise ──────────────────────────────────────────────────────
# Your Splunk Enterprise instance. The MCP token is from the Splunkbase
# MCP Server app (app 7931), specifically its /mcp_token endpoint.
SPLUNK_BASE_URL=https://splunk.example.com:8089
SPLUNK_WEB_URL=https://splunk.example.com:8000
SPLUNK_MCP_TOKEN=replace-me-with-bearer-token
SPLUNK_HEC_URL=https://splunk.example.com:8088/services/collector
SPLUNK_HEC_TOKEN=replace-me-with-hec-token
SPLUNK_HEC_INDEX=main
SPLUNK_USERNAME=admin
SPLUNK_APP=search
SPLUNK_OUTPUT_MODE=json

# ─── Public (NEXT_PUBLIC_*) — safe to expose to client bundle ──────────────
NEXT_PUBLIC_SPLUNK_WEB_URL=https://splunk.example.com:8000
